    "esbuild": "^0.24.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "htmx.org": "^2.0.4",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.0"
  }
